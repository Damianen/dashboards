# Public OAuth callback relay — config only, no secrets.
# Fixed tailnet host to bounce the browser to. Set to your HEALTH app's Tailscale
# URL (get the node name from `tailscale serve status`).
RELAY_TARGET_HOST=https://<node>.tail94f1b7.ts.net
# Comma-separated exact callback paths to forward. Add Oura's when you wire it up:
#   /api/oauth/withings/callback,/api/oauth/oura/callback
RELAY_ALLOWED_PATHS=/api/oauth/withings/callback
PORT=3003
