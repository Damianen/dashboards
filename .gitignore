# dependencies
node_modules/

# env — only the *.example templates are committed
.env
.env.*
!.env.example
!.env.production.example

# private keys (e.g. Enable Banking) must never be committed
*.pem
*.key

# builds
dist/
.next/
out/
*.tsbuildinfo

# tests
coverage/

# postgres data volume (if bind-mounted) + local backup dumps
infra/postgres/data/
infra/postgres/backups/
infra/postgres/backup.log

# next.js
next-env.d.ts
.vercel

# generated prisma client
apps/*/src/generated/

# serwist — service worker generated at build time
apps/*/public/sw.js
apps/*/public/sw.js.map
apps/*/public/swe-worker-*.js

# misc
.DS_Store
