# apps/finance — production env. Copy to .env.production and fill the secrets.
# The unified `scripts/up.sh` generates this file and auto-fills DATABASE_URL +
# FINANCE_MCP_TOKEN; the Enable Banking values below are left for you.
# See docs/ENVIRONMENT.md.

# Prod role finance_app / db finance, minted by create-service.sh finance.
# Host is "postgres" (the shared server on the homelab network), not localhost.
DATABASE_URL=postgresql://finance_app:<password>@postgres:5432/finance?connection_limit=5

# Enable Banking (enablebanking.com control panel — restricted/personal app).
EB_APP_ID=
# Path INSIDE the container where the EB private key is mounted (see compose).
EB_PRIVATE_KEY_PATH=/run/secrets/eb-finance.pem
# Host path to the EB private key that compose mounts read-only at the path
# above. Keep the key out of the repo and the image (*.pem is git-ignored).
EB_PRIVATE_KEY_HOST_PATH=./apps/finance/eb-finance.pem
# Must be registered in the EB portal (prod domain):
EB_REDIRECT_URL=https://finance.<your-domain>/api/eb/callback
# false in prod once EB_APP_ID + the private key reach the real banks.
EB_SANDBOX=false
# Enable Banking API base. Sandbox shares the production host.
EB_API_BASE=https://api.enablebanking.com

# Bearer token guarding POST /api/mcp (timing-safe compare). Generate: openssl rand -hex 32
FINANCE_MCP_TOKEN=

# ntfy push notifications (budget alerts, re-consent reminders).
# A logged no-op until NTFY_TOPIC is set.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
# Public base URL of this app, makes notification tap-through links absolute.
APP_BASE_URL=https://finance.<your-domain>

# Timezone for booking-date bucketing and scheduled syncs.
TZ=Europe/Amsterdam
