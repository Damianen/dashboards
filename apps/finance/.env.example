# DATABASE_URL is minted by infra/postgres/scripts/create-service.sh:
#   ./create-service.sh finance_dev   # local dev (host: localhost)
#   ./create-service.sh finance       # prod (host: postgres, homelab network)
DATABASE_URL=postgresql://finance_dev_app:<password>@localhost:5432/finance_dev?connection_limit=5

# Enable Banking (enablebanking.com control panel — restricted/personal app)
EB_APP_ID=
# Private key downloaded once from the EB portal. Keep it OUTSIDE the repo
# (e.g. ~/.secrets/eb-finance.pem on the host; /run/secrets/eb-finance.pem
# in the container).
EB_PRIVATE_KEY_PATH=
# Must be registered in the EB portal:
#   dev:  http://localhost:3000/api/eb/callback
#   prod: https://finance.<your-domain>/api/eb/callback
EB_REDIRECT_URL=http://localhost:3000/api/eb/callback
# Sandbox: route "Connect ING/Revolut" to Enable Banking's "Mock ASPSP" so the
# full consent + sync flow can be exercised before real bank consent exists.
# Keep true in dev; set false once EB_APP_ID + the private key reach the real banks.
EB_SANDBOX=true
# API base. Sandbox shares the production host; override only for tests.
EB_API_BASE=https://api.enablebanking.com

# Bearer token for /api/mcp — generate with: openssl rand -hex 32
FINANCE_MCP_TOKEN=

# ntfy push notifications (budget alerts, re-consent reminders).
# A logged no-op until NTFY_TOPIC is set.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
# Optional: base URL of this app, used to make notification tap-through links
# absolute (e.g. https://finance.<your-domain>). Falls back to relative paths.
APP_BASE_URL=

TZ=Europe/Amsterdam
