// finance — authoritative data model. Read apps/finance/CLAUDE.md before
// touching anything data-related; the money & time invariants live there.
//
// - Amounts are Decimal(12,2), never floats. Bank sign convention is kept:
//   negative = outflow, positive = inflow.
// - A Transaction is immutable after ingest EXCEPT: categoryId, merchantKey,
//   isInternalTransfer, transferPairId, notes.
// - Dedupe key is @@unique([accountId, externalId]); re-running a sync window
//   must be a no-op (upsert).
// - This slice wires BankConnection / Account / Transaction / BalanceSnapshot.
//   Category, CategoryRule, Budget, RecurringSeries and NotificationLog exist
//   so later slices EXTEND (never rename) them — no service touches them yet.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql" // url lives in prisma.config.ts (Prisma 7)
}

enum Bank {
  ING
  REVOLUT
}

enum ConnectionStatus {
  PENDING // /auth started, awaiting the bank redirect
  AUTHORIZED // session live, accounts known
  EXPIRED // valid_until passed or session revoked — needs re-consent
  ERROR
}

enum CreditDebit {
  CRDT // inflow
  DBIT // outflow
}

enum TransactionStatus {
  BOOK
  PENDING
}

enum RuleField {
  merchant
  counterparty_iban
  description
}

enum RuleMatch {
  contains
  regex
  exact
}

model BankConnection {
  id            String           @id @default(cuid())
  bank          Bank
  aspspName     String
  aspspCountry  String
  psuType       String           @default("personal")
  // CSRF/lookup token tying the bank's redirect back to this row.
  state         String           @unique
  sessionId     String?
  validUntil    DateTime?
  status        ConnectionStatus @default(PENDING)
  authorizedAt  DateTime?
  // Null until the first post-consent sync finishes its history backfill.
  initialSyncAt DateTime?
  lastSyncedAt  DateTime?
  lastError     String?
  // Failed sync runs since the last success; reset to 0 on a successful sync.
  // 3+ triggers a re-consent reminder (src/lib/sync-health.ts).
  consecutiveFailures Int        @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]

  @@index([bank, status])
}

model Account {
  id              String            @id @default(cuid())
  connectionId    String
  connection      BankConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  // Enable Banking account uid — the handle used for all account endpoints.
  externalUid     String            @unique
  iban            String?
  name            String?
  currency        String            @default("EUR")
  cashAccountType String?
  product         String?
  lastBookingDate DateTime?         @db.Date
  lastSyncedAt    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  transactions    Transaction[]
  balances        BalanceSnapshot[]

  @@index([connectionId])
}

model Transaction {
  id          String            @id @default(cuid())
  accountId   String
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Stable bank id (entry_reference / transaction_id) or sha256 fallback.
  externalId  String
  bookingDate DateTime          @db.Date
  valueDate   DateTime?         @db.Date
  // Signed, bank convention: negative = outflow, positive = inflow.
  amount      Decimal           @db.Decimal(12, 2)
  currency    String            @default("EUR")
  creditDebit CreditDebit
  status      TransactionStatus @default(BOOK)
  counterparty        String?
  counterpartyIban    String?
  descriptionRaw      String?
  bankTransactionCode String?

  // --- mutable after ingest (apps/finance/CLAUDE.md); unused this slice ---
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchantKey        String?
  isInternalTransfer Boolean   @default(false)
  transferPairId     String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, externalId])
  @@index([accountId, bookingDate(sort: Desc)])
  @@index([categoryId])
  @@index([merchantKey])
  @@index([transferPairId])
}

model BalanceSnapshot {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("EUR")
  balanceType String?
  createdAt   DateTime @default(now())

  @@unique([accountId, date])
}

// ---------------------------------------------------------------------------
// Defined for later slices (categorization, budgets, subscriptions). No
// service reads or writes these yet — present so the schema is extended,
// never renamed, when those slices land.
// ---------------------------------------------------------------------------

model Category {
  id           String         @id @default(cuid())
  name         String         @unique
  // "income" | "expense" — string to avoid over-modeling before first use.
  kind         String         @default("expense")
  color        String         @default("#808080")
  parentId     String?
  parent       Category?      @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]     @relation("CategoryTree")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  transactions Transaction[]
  rules        CategoryRule[]
  budgets      Budget[]

  @@index([parentId])
}

model CategoryRule {
  id         String    @id @default(cuid())
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  priority   Int       @default(100)
  field      RuleField
  match      RuleMatch
  value      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([categoryId])
  @@index([priority])
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // First day of the budget month (local); Decimal monthly limit.
  month      DateTime @db.Date
  limit      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, month])
}

model RecurringSeries {
  id             String    @id @default(cuid())
  merchantKey    String    @unique
  description    String?
  expectedAmount Decimal   @db.Decimal(12, 2)
  intervalDays   Int
  lastSeenDate   DateTime? @db.Date
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model NotificationLog {
  id        String   @id @default(cuid())
  // e.g. budgetId:YYYY-MM:80 — guarantees an alert fires at most once.
  dedupeKey String   @unique
  kind      String
  sentAt    DateTime @default(now())
}

// Generic key/value app settings. Typed access lives in
// src/server/services/settings.ts (e.g. large_txn_threshold_eur, parsed to a
// Decimal). Key/value avoids a migration per new setting.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
