# Production env for apps/health. Copy to .env.production and fill the secrets.
# DATABASE_URL: prod role health_app / db health, minted by
# infra/postgres/scripts/create-service.sh — host is "postgres" on the homelab net.
DATABASE_URL=postgresql://health_app:<password>@postgres:5432/health
MCP_BEARER_TOKEN=        # openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=    # 32 bytes base64 (openssl rand -base64 32) — AES-256-GCM for oauth_tokens
OURA_PAT=                # personal access token from cloud.ouraring.com
SYNC_BACKFILL_DAYS=90    # first-run backfill window (days); incremental runs use a 3-day overlap
ENABLE_SCHEDULER=true    # prod runs the in-process croner scheduler
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=https://health.<your-domain>/api/oauth/withings/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://health.<your-domain>/api/oauth/google/callback
OFF_USER_AGENT=          # e.g. "health-dashboard/0.1 (you@example.com)" — Open Food Facts requires it
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=           # mailto:you@example.com
APP_BASE_URL=https://health.<your-domain>
TZ=Europe/Amsterdam
