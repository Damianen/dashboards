# apps/health — production env. Copy to .env.production and fill the secrets.
# The unified `scripts/up.sh` generates this file and auto-fills the secrets it
# can (DATABASE_URL, MCP_BEARER_TOKEN, TOKEN_ENCRYPTION_KEY, VAPID keys); the
# third-party credentials below are left for you. See docs/ENVIRONMENT.md.

# Prod role health_app / db health, minted by create-service.sh health.
# Host is "postgres" (the shared server on the homelab network), not localhost.
DATABASE_URL=postgresql://health_app:<password>@postgres:5432/health

# Bearer token guarding POST /api/mcp (timing-safe compare). Generate: openssl rand -base64 32
MCP_BEARER_TOKEN=
# AES-256-GCM key encrypting Withings/Google OAuth tokens at rest in oauth_tokens.
# MUST decode to exactly 32 bytes. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Oura OAuth2 app (cloud.ouraring.com → register an API Application). Oura matches the
# registered redirect URI without a reachability check, so point it at the Tailscale URL
# directly (the callback does not need the Cloudflare hop). Must match the portal exactly.
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=https://<machine>.<tailnet>.ts.net/api/oauth/oura/callback
# First-run backfill window in days; incremental syncs use a 3-day overlap.
SYNC_BACKFILL_DAYS=90
# Prod runs the in-process croner scheduler.
ENABLE_SCHEDULER=true

# Withings OAuth app (developer.withings.com). Redirect URI must match the portal exactly.
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=https://health.<your-domain>/api/oauth/withings/callback

# Google OAuth 2.0 Web client (Google Cloud Console) for the Google Health API.
# Redirect URI must match an authorized redirect URI on the client exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://health.<your-domain>/api/oauth/google/callback

# User-Agent string Open Food Facts requires on every API call (identify your app).
OFF_USER_AGENT=          # e.g. "health-dashboard/0.1 (you@example.com)"

# Provider-agnostic meal-photo / nutrition-label vision (OpenAI-compatible API).
# Required for meal-photo + label scanning; the vision service throws if unset.
VISION_API_BASE_URL=     # chat-completions base, e.g. https://openrouter.ai/api/v1
VISION_API_KEY=          # API key for that provider
VISION_MODEL=            # a current vision-capable model id (set per provider; never hardcode)

# Web Push (VAPID) keypair — generate with: npx web-push generate-vapid-keys
# Optional: push notifications are disabled until all three are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=           # mailto:you@example.com

# Public base URL of this app, used for push notification deep links.
APP_BASE_URL=https://health.<your-domain>
# Timezone for day-bucketing and schedules.
TZ=Europe/Amsterdam
