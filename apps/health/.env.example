DATABASE_URL=            # health_dev locally, health in prod — minted by infra/postgres/scripts/create-service.sh
MCP_BEARER_TOKEN=        # openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=    # 32 bytes base64 (openssl rand -base64 32) — AES-256-GCM for oauth_tokens
OURA_PAT=                # personal access token from cloud.ouraring.com
SYNC_BACKFILL_DAYS=90    # first-run backfill window (days); incremental runs use a 3-day overlap
ENABLE_SCHEDULER=        # "true" runs the in-process croner scheduler (off by default; prod only)
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:3000/api/oauth/withings/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
OFF_USER_AGENT=          # e.g. "health-dashboard/0.1 (you@example.com)" — Open Food Facts requires it
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=           # mailto:you@example.com
APP_BASE_URL=http://localhost:3000
TZ=Europe/Amsterdam
