generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql" // url lives in prisma.config.ts (Prisma 7)
}

enum Source {
  WITHINGS
  OURA
  GOOGLE_HEALTH
  MANUAL
}

enum EntryOrigin {
  PWA
  MCP
}

enum SupplementTimeGroup {
  MORNING
  EVENING
  PRE_WORKOUT
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum SyncSource {
  OURA
  WITHINGS
  GOOGLE_HEALTH
}

enum SyncStatus {
  RUNNING
  OK
  ERROR
}

enum OauthProvider {
  WITHINGS
  GOOGLE
  OURA
}

enum TemplateTargetType {
  REPS
  VOLUME
}

enum WarmupWeightMode {
  ABSOLUTE
  PERCENT
}

model WeightMeasurement {
  id           String   @id @default(cuid())
  measuredAt   DateTime @map("measured_at") @db.Timestamptz(6)
  day          DateTime @db.Date
  weightKg     Decimal  @map("weight_kg") @db.Decimal(5, 2)
  bodyFatPct   Decimal? @map("body_fat_pct") @db.Decimal(4, 1)
  muscleMassKg Decimal? @map("muscle_mass_kg") @db.Decimal(5, 2)
  hydrationKg  Decimal? @map("hydration_kg") @db.Decimal(5, 2)
  boneMassKg   Decimal? @map("bone_mass_kg") @db.Decimal(4, 2)
  source       Source   @default(WITHINGS)
  externalId   String?  @unique @map("external_id")
  raw          Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([day])
  @@map("weight_measurements")
}

model SleepSession {
  id            String   @id @default(cuid())
  day           DateTime @db.Date
  bedtimeStart  DateTime @map("bedtime_start") @db.Timestamptz(6)
  bedtimeEnd    DateTime @map("bedtime_end") @db.Timestamptz(6)
  totalSleepMin Int      @map("total_sleep_min")
  deepMin       Int?     @map("deep_min")
  remMin        Int?     @map("rem_min")
  lightMin      Int?     @map("light_min")
  awakeMin      Int?     @map("awake_min")
  efficiency    Int?
  latencySec    Int?     @map("latency_sec")
  avgHrBpm      Decimal? @map("avg_hr_bpm") @db.Decimal(5, 2)
  avgHrvMs      Int?     @map("avg_hrv_ms")
  lowestHrBpm   Int?     @map("lowest_hr_bpm")
  source        Source   @default(OURA)
  externalId    String   @unique @map("external_id")
  raw           Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([day])
  @@map("sleep_sessions")
}

model DailySleep {
  day       DateTime @id @db.Date
  score     Int?
  raw       Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("daily_sleep")
}

model DailyReadiness {
  day                  DateTime @id @db.Date
  score                Int?
  temperatureDeviation Decimal? @map("temperature_deviation") @db.Decimal(4, 2)
  restingHrBpm         Int?     @map("resting_hr_bpm")
  hrvBalance           Int?     @map("hrv_balance")
  raw                  Json?
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("daily_readiness")
}

model DailyActivity {
  day        DateTime @id @db.Date
  activeKcal Int?     @map("active_kcal")
  totalKcal  Int?     @map("total_kcal")
  steps      Int?
  source     Source   @default(GOOGLE_HEALTH)
  raw        Json?
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("daily_activity")
}

model FoodProduct {
  barcode   String      @id
  name      String
  brand     String?
  imageUrl  String?     @map("image_url")
  per100g   Json
  servingG  Decimal?    @map("serving_g") @db.Decimal(7, 1)
  raw       Json?
  fetchedAt DateTime    @map("fetched_at")
  entries   FoodEntry[]
  mealItems MealItem[]

  @@map("food_products")
}

model FoodEntry {
  id             String       @id @default(cuid())
  eatenAt        DateTime     @map("eaten_at") @db.Timestamptz(6)
  day            DateTime     @db.Date
  productBarcode String?      @map("product_barcode")
  product        FoodProduct? @relation(fields: [productBarcode], references: [barcode])
  customName     String?      @map("custom_name")
  customFoodId   String?      @map("custom_food_id")
  customFood     CustomFood?  @relation(fields: [customFoodId], references: [id])
  // A meal-logged entry: the recipe it came from and the portion count chosen.
  // quantityG is null for these (they're measured in portions, not grams).
  mealId         String?      @map("meal_id")
  recipe         Meal?        @relation(fields: [mealId], references: [id])
  portions       Decimal?     @db.Decimal(6, 2)
  quantityG      Decimal?     @map("quantity_g") @db.Decimal(7, 1)
  kcal           Decimal      @db.Decimal(7, 1)
  proteinG       Decimal      @map("protein_g") @db.Decimal(6, 1)
  carbG          Decimal      @map("carb_g") @db.Decimal(6, 1)
  fatG           Decimal      @map("fat_g") @db.Decimal(6, 1)
  fiberG         Decimal?     @map("fiber_g") @db.Decimal(6, 1)
  sugarG         Decimal?     @map("sugar_g") @db.Decimal(6, 1)
  saltG          Decimal?     @map("salt_g") @db.Decimal(6, 2)
  // Snapshot of this entry's caffeine (mg), already scaled to quantity/portions.
  // Null when unknown (never 0). Feeds only the unified daily caffeine total /
  // water target — never any calorie column.
  caffeineMg     Decimal?     @map("caffeine_mg") @db.Decimal(7, 1)
  micros         Json?
  meal           MealSlot?
  origin         EntryOrigin
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([day])
  @@map("food_entries")
}

model CustomFood {
  id        String      @id @default(cuid())
  name      String
  brand     String?
  per100g   Json
  servingG  Decimal?    @map("serving_g") @db.Decimal(7, 1)
  source    String // "LABEL_SCAN" | "MANUAL" (enforced by Zod at the boundary)
  createdAt DateTime    @default(now()) @map("created_at")
  entries   FoodEntry[]
  mealItems MealItem[]

  @@index([name])
  @@map("custom_foods")
}

/// A saved recipe: a list of ingredient items plus a yield (how many portions it
/// makes). `perPortion` is the macro snapshot PER portion, computed and stored at
/// save time so logging it and editing it stay decoupled (CLAUDE.md snapshot rule).
model Meal {
  id            String      @id @default(cuid())
  name          String
  notes         String?
  yieldPortions Decimal     @map("yield_portions") @db.Decimal(6, 2)
  // {kcal,proteinG,carbG,fatG,fiberG?,sugarG?,saltG?,caffeineMg?} — same shape as
  // Macros (nulls kept). caffeineMg (mg) rides along so a caffeinated meal feeds the
  // unified daily caffeine total / water target when logged.
  perPortion    Json        @map("per_portion")
  archived      Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  items         MealItem[]  @relation("MealItems")
  usedIn        MealItem[]  @relation("MealChild")
  entries       FoodEntry[]

  @@index([archived])
  @@map("meals")
}

/// One ingredient of a Meal. Exactly one source is set (enforced in Zod + the
/// service), mirroring FoodEntry's resolution and adding a nested-meal source.
/// The macro columns hold this item's computed contribution to the meal total
/// (a snapshot); for a free-typed item they ARE its entered macros.
model MealItem {
  id             String       @id @default(cuid())
  mealId         String       @map("meal_id")
  meal           Meal         @relation("MealItems", fields: [mealId], references: [id], onDelete: Cascade)
  position       Int
  productBarcode String?      @map("product_barcode")
  product        FoodProduct? @relation(fields: [productBarcode], references: [barcode])
  customFoodId   String?      @map("custom_food_id")
  customFood     CustomFood?  @relation(fields: [customFoodId], references: [id])
  customName     String?      @map("custom_name")
  childMealId    String?      @map("child_meal_id")
  childMeal      Meal?        @relation("MealChild", fields: [childMealId], references: [id])
  quantityG      Decimal?     @map("quantity_g") @db.Decimal(7, 1)
  childPortions  Decimal?     @map("child_portions") @db.Decimal(6, 2)
  kcal           Decimal?     @db.Decimal(7, 1)
  proteinG       Decimal?     @map("protein_g") @db.Decimal(6, 1)
  carbG          Decimal?     @map("carb_g") @db.Decimal(6, 1)
  fatG           Decimal?     @map("fat_g") @db.Decimal(6, 1)
  fiberG         Decimal?     @map("fiber_g") @db.Decimal(6, 1)
  sugarG         Decimal?     @map("sugar_g") @db.Decimal(6, 1)
  saltG          Decimal?     @map("salt_g") @db.Decimal(6, 2)
  caffeineMg     Decimal?     @map("caffeine_mg") @db.Decimal(7, 1)

  @@index([mealId])
  @@index([childMealId])
  @@map("meal_items")
}

model Exercise {
  id              String             @id @default(cuid())
  name            String             @unique
  muscleGroup     String?            @map("muscle_group")
  sets            LiftingSet[]
  templateEntries TemplateExercise[]
  planItems       SessionPlanItem[]

  @@map("exercises")
}

model LiftingSession {
  id         String            @id @default(cuid())
  day        DateTime          @db.Date
  startedAt  DateTime          @map("started_at") @db.Timestamptz(6)
  endedAt    DateTime?         @map("ended_at") @db.Timestamptz(6)
  notes      String?
  templateId String?           @map("template_id")
  template   WorkoutTemplate?  @relation(fields: [templateId], references: [id])
  sets       LiftingSet[]
  planItems  SessionPlanItem[]

  @@index([day])
  @@map("lifting_sessions")
}

model LiftingSet {
  id         String         @id @default(cuid())
  sessionId  String         @map("session_id")
  session    LiftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String         @map("exercise_id")
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  setNumber  Int            @map("set_number")
  reps       Int
  weightKg   Decimal        @map("weight_kg") @db.Decimal(5, 2)
  rpe        Decimal?       @db.Decimal(3, 1)
  isWarmup   Boolean        @default(false) @map("is_warmup")
  loggedAt   DateTime       @default(now()) @map("logged_at") @db.Timestamptz(6)
  origin     EntryOrigin

  @@index([exerciseId, loggedAt])
  @@map("lifting_sets")
}

/// Apple Watch cardio/HealthKit workout pushed from Health Auto Export (HAE)
/// over Tailscale — distinct from LiftingSession (lifting-specific). One row per
/// workout, keyed on externalId so HAE's overlapping re-sends stay idempotent.
model Workout {
  id               String    @id @default(cuid())
  externalId       String    @unique @map("external_id")
  source           String    @default("apple_health")
  type             String
  name             String?
  startedAt        DateTime  @map("started_at") @db.Timestamptz(6)
  endedAt          DateTime? @map("ended_at") @db.Timestamptz(6)
  durationSeconds  Int?      @map("duration_seconds")
  day              DateTime  @db.Date
  distance         Float?
  activeEnergyKcal Float?    @map("active_energy_kcal")
  avgHeartRate     Int?      @map("avg_heart_rate")
  maxHeartRate     Int?      @map("max_heart_rate")
  raw              Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([day])
  @@map("workouts")
}

model WorkoutTemplate {
  id        String             @id @default(cuid())
  name      String             @unique
  notes     String?
  archived  Boolean            @default(false)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  exercises TemplateExercise[]
  sessions  LiftingSession[]

  @@map("workout_templates")
}

model TemplateExercise {
  id                String              @id @default(cuid())
  templateId        String              @map("template_id")
  template          WorkoutTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId        String              @map("exercise_id")
  exercise          Exercise            @relation(fields: [exerciseId], references: [id])
  position          Int
  targetType        TemplateTargetType  @default(REPS) @map("target_type")
  targetSets        Int?                @map("target_sets")
  repMin            Int?                @map("rep_min")
  repMax            Int?                @map("rep_max")
  targetWeightKg    Decimal?            @map("target_weight_kg") @db.Decimal(5, 2)
  weightIncrementKg Decimal?            @map("weight_increment_kg") @db.Decimal(5, 2)
  targetVolumeKg    Decimal?            @map("target_volume_kg") @db.Decimal(7, 1)
  restSec           Int?                @map("rest_sec")
  notes             String?
  warmups           TemplateWarmupSet[]

  @@unique([templateId, position])
  @@index([templateId])
  @@map("template_exercises")
}

/// An ordered warmup set pre-defined on a template exercise. Its weight is either
/// an absolute kg (weightKg, ABSOLUTE mode) or a percentage of the exercise's
/// working weight (percentOfWorking, PERCENT mode) — exactly one is set per mode.
/// Warmups never count toward volume or progression; they only seed the logger.
model TemplateWarmupSet {
  id                 String           @id @default(cuid())
  templateExerciseId String           @map("template_exercise_id")
  templateExercise   TemplateExercise @relation(fields: [templateExerciseId], references: [id], onDelete: Cascade)
  position           Int
  reps               Int
  weightMode         WarmupWeightMode @map("weight_mode")
  weightKg           Decimal?         @map("weight_kg") @db.Decimal(5, 2)
  percentOfWorking   Decimal?         @map("percent_of_working") @db.Decimal(5, 2)

  @@unique([templateExerciseId, position])
  @@index([templateExerciseId])
  @@map("template_warmup_sets")
}

model SessionPlanItem {
  id                String              @id @default(cuid())
  sessionId         String              @map("session_id")
  session           LiftingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId        String              @map("exercise_id")
  exercise          Exercise            @relation(fields: [exerciseId], references: [id])
  position          Int
  targetType        TemplateTargetType  @default(REPS) @map("target_type")
  targetSets        Int?                @map("target_sets")
  repMin            Int?                @map("rep_min")
  repMax            Int?                @map("rep_max")
  targetWeightKg    Decimal?            @map("target_weight_kg") @db.Decimal(5, 2)
  weightIncrementKg Decimal?            @map("weight_increment_kg") @db.Decimal(5, 2)
  targetVolumeKg    Decimal?            @map("target_volume_kg") @db.Decimal(7, 1)
  warmups           SessionPlanWarmup[]

  @@unique([sessionId, position])
  @@index([sessionId])
  @@map("session_plan_items")
}

/// Per-session snapshot of a template exercise's warmup definitions, copied when a
/// workout starts so later template edits never rewrite an in-progress/past
/// session. Same shape as TemplateWarmupSet (additive snapshot, like SessionPlanItem).
model SessionPlanWarmup {
  id               String           @id @default(cuid())
  planItemId       String           @map("plan_item_id")
  planItem         SessionPlanItem  @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  position         Int
  reps             Int
  weightMode       WarmupWeightMode @map("weight_mode")
  weightKg         Decimal?         @map("weight_kg") @db.Decimal(5, 2)
  percentOfWorking Decimal?         @map("percent_of_working") @db.Decimal(5, 2)

  @@unique([planItemId, position])
  @@index([planItemId])
  @@map("session_plan_warmups")
}

model WaterEntry {
  id       String      @id @default(cuid())
  loggedAt DateTime    @map("logged_at") @db.Timestamptz(6)
  day      DateTime    @db.Date
  amountMl Int         @map("amount_ml")
  origin   EntryOrigin

  @@index([day])
  @@map("water_entries")
}

model StimulantEntry {
  id        String      @id @default(cuid())
  loggedAt  DateTime    @map("logged_at") @db.Timestamptz(6)
  day       DateTime    @db.Date
  substance String      @default("caffeine")
  amountMg  Decimal     @map("amount_mg") @db.Decimal(7, 1)
  origin    EntryOrigin
  notes     String?

  @@index([day])
  @@map("stimulant_entries")
}

// Legacy ad-hoc supplement log — retained so existing rows survive (no new writes).
// Superseded by the Supplement / SupplementLog checklist below. Do NOT drop.
model SupplementEntry {
  id       String      @id @default(cuid())
  loggedAt DateTime    @map("logged_at") @db.Timestamptz(6)
  day      DateTime    @db.Date
  name     String
  dose     Decimal     @db.Decimal(8, 2)
  unit     String
  origin   EntryOrigin

  @@index([day])
  @@map("supplement_entries")
}

// A supplement on the user's managed daily list. Grouped by time of day and
// ordered within its group by `position`. Archived (not deleted) to retire one
// without losing its logged history.
model Supplement {
  id         String              @id @default(cuid())
  name       String
  dose       Decimal             @db.Decimal(8, 2)
  unit       String
  // Caffeine per dose (mg), e.g. a pre-workout. Null when not caffeinated. Snapshotted
  // onto each SupplementLog at check time; editing it never rewrites past days.
  caffeineMg Decimal?            @map("caffeine_mg") @db.Decimal(7, 1)
  timeGroup  SupplementTimeGroup @map("time_group")
  position   Int
  archived   Boolean             @default(false)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  logs       SupplementLog[]

  @@index([timeGroup, position])
  @@map("supplements")
}

// One "taken today" tick. Exactly one row per supplement per civil day (the
// unique key makes checking idempotent); dose/unit/caffeine are snapshotted at check
// time so later edits to the supplement never rewrite past days.
model SupplementLog {
  id               String      @id @default(cuid())
  supplementId     String      @map("supplement_id")
  supplement       Supplement  @relation(fields: [supplementId], references: [id])
  day              DateTime    @db.Date
  takenAt          DateTime    @map("taken_at") @db.Timestamptz(6)
  doseSnapshot     Decimal     @map("dose_snapshot") @db.Decimal(8, 2)
  unitSnapshot     String      @map("unit_snapshot")
  // Snapshot of the supplement's caffeineMg at check time (mg). Null when the
  // supplement carries no caffeine. Summed into the day's unified caffeine total.
  caffeineSnapshot Decimal?    @map("caffeine_snapshot") @db.Decimal(7, 1)
  origin           EntryOrigin

  @@unique([supplementId, day])
  @@index([day])
  @@map("supplement_logs")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model PushSubscription {
  endpoint  String   @id
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  failCount Int      @default(0) @map("fail_count")

  @@map("push_subscriptions")
}

// One row per observation we've pushed. observationId is unique so a given observation
// never re-fires (dedupe); `day` records when it fired so the digest can hold to ~1
// push/day (throttle). Append-only bookkeeping — nothing else reads it.
model NotifiedObservation {
  id            String   @id @default(cuid())
  observationId String   @unique @map("observation_id")
  day           DateTime @db.Date
  notifiedAt    DateTime @default(now()) @map("notified_at") @db.Timestamptz(6)

  @@index([day])
  @@map("notified_observations")
}

// One row per streak milestone we've celebrated. The dedupe key is
// (streakType, milestone, startDay): a given milestone fires once per streak RUN, but a
// fresh streak (new startDay) celebrates again. startDay also lets a missed/no-subscriber
// day re-fire on a later day (we push on length ≥ milestone, not only the exact day).
// Append-only bookkeeping — nothing else reads it.
model NotifiedStreakMilestone {
  id         String   @id @default(cuid())
  streakType String   @map("streak_type")
  milestone  Int
  startDay   DateTime @map("start_day") @db.Date
  notifiedAt DateTime @default(now()) @map("notified_at") @db.Timestamptz(6)

  @@unique([streakType, milestone, startDay])
  @@map("notified_streak_milestones")
}

model OauthToken {
  provider        OauthProvider @id
  accessTokenEnc  String        @map("access_token_enc")
  refreshTokenEnc String        @map("refresh_token_enc")
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz(6)
  scope           String?
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("oauth_tokens")
}

model SyncRun {
  id            String     @id @default(cuid())
  source        SyncSource
  startedAt     DateTime   @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime?  @map("finished_at") @db.Timestamptz(6)
  status        SyncStatus @default(RUNNING)
  itemsUpserted Int        @default(0) @map("items_upserted")
  windowStart   DateTime?  @map("window_start") @db.Timestamptz(6)
  windowEnd     DateTime?  @map("window_end") @db.Timestamptz(6)
  error         String?

  @@index([source, startedAt])
  @@map("sync_runs")
}
