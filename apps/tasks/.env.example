# DATABASE_URL is minted by infra/postgres/scripts/create-service.sh:
#   ./create-service.sh tasks_dev   # local dev (host: localhost)
#   ./create-service.sh tasks       # prod (host: postgres, homelab network)
DATABASE_URL=postgresql://tasks_dev_app:<password>@localhost:5432/tasks_dev?connection_limit=5

# Bearer token for /api/mcp — generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=

# ntfy push notifications. NTFY_URL is the ntfy server base URL; reminders are
# published as JSON to it on the NTFY_TOPIC topic.
NTFY_URL=
NTFY_TOPIC=

# Base URL of this app, used for the reminder push click action
# (e.g. https://tasks.example.com -> click opens /today?task=<id>).
APP_URL=

# Set to 1 in exactly one process to run the reminder cron worker. Leave unset
# in extra `next dev`/`next start` processes so notifications don't double-fire.
RUN_WORKER=

# Timezone for due-date interpretation and reminder scheduling.
TZ=Europe/Amsterdam
