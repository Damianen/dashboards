# apps/tasks — production env. Copy to .env.production and fill the secrets.
# The unified `scripts/up.sh` generates this file and auto-fills DATABASE_URL +
# MCP_BEARER_TOKEN; the rest is optional. See docs/ENVIRONMENT.md.

# Prod role tasks_app / db tasks, minted by create-service.sh tasks.
# Host is "postgres" (the shared server on the homelab network), not localhost.
DATABASE_URL=postgresql://tasks_app:<password>@postgres:5432/tasks?connection_limit=5

# Bearer token guarding POST /api/mcp (timing-safe compare). Generate: openssl rand -hex 32
MCP_BEARER_TOKEN=

# ntfy push notifications. NTFY_URL is the ntfy server base URL; reminders are
# published as JSON to it on the NTFY_TOPIC topic. Leave blank to disable.
NTFY_URL=
NTFY_TOPIC=

# Public base URL of this app, used for the reminder push click action
# (e.g. https://tasks.<your-domain> -> click opens /today?task=<id>).
APP_URL=https://tasks.<your-domain>

# Set to 1 so this container runs the reminder cron worker. In prod there is one
# container, so it should be the worker. Keep unset in any extra processes.
RUN_WORKER=1

# Timezone for due-date interpretation and reminder scheduling.
TZ=Europe/Amsterdam
